# WalkWithMe Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# REQUIRED — Valhalla routing engine
# ---------------------------------------------------------------------------
# URL of your Valhalla instance (DigitalOcean droplet or self-hosted)
VALHALLA_URL=http://165.227.188.199:8002

# Request timeout for Valhalla calls (seconds)
# Increase if your Valhalla instance is on a slow connection
VALHALLA_TIMEOUT=10

# ---------------------------------------------------------------------------
# OPTIONAL — Google Places API
# ---------------------------------------------------------------------------
# Used for: /autocomplete (POI fallback), /places_search endpoint
# Get a key: https://console.cloud.google.com → APIs → Places API
# If not set, OSM/Photon/Nominatim is used instead (free, slightly less POI-aware)
GOOGLE_PLACES_API_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL — OpenAI
# ---------------------------------------------------------------------------
# Used for: /vision endpoint (AR hazard interpretation)
# If not set, /vision returns 503
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL — Overpass API (route enrichment)
# ---------------------------------------------------------------------------
# Default is the public Overpass instance — fine for development
# For production, consider self-hosting: https://overpass-api.de/
# or using overpass.kumi.systems as an alternative
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Timeout for Overpass queries (seconds)
OVERPASS_TIMEOUT=6

# ---------------------------------------------------------------------------
# OPTIONAL — Enrichment tuning
# ---------------------------------------------------------------------------
# Max distance from route for a POI to be included (meters)
# 150 = right along the path, 300 = slightly looser
ENRICHMENT_CORRIDOR_M=150

# Max results per category in route enrichment
ENRICHMENT_MAX_LANDMARKS=8
ENRICHMENT_MAX_FOOD=8

# ---------------------------------------------------------------------------
# OPTIONAL — Walking speed (for loop distance calculation)
# ---------------------------------------------------------------------------
# Used to convert loop duration (minutes) to target distance (km)
# Default 5.0 km/h is a comfortable city walk pace
WALK_SPEED_KPH=5.0
